# fuse4dbricks — environment for live / end-to-end tests
#
# Copy this file to .env and fill in real values:
#
#     cp .env.example .env
#     $EDITOR .env
#
# .env is gitignored (this .env.example is the only one committed). Load it
# into your shell before running the tests or mounting, so the values reach
# both the fuse4dbricks process and the commands that read the mount:
#
#     set -a; source .env; set +a
#
# What it feeds:
#   - DATABRICKS_HOST / DATABRICKS_TOKEN are the standard Databricks variables.
#     With them set, the credential-free unit tests still run AND the live
#     uc_client integration tests stop skipping:
#         pytest tests/test_uc_client_integration.py
#   - The FUSE4DBRICKS_TEST_* variables below target a real volume for the
#     end-to-end mount smoke test (real readdir / getattr / read / EACCES).


# --- Databricks workspace + credentials -------------------------------------

# Workspace URL of your Databricks instance.
DATABRICKS_HOST="https://adb-xxxxxxxxxxxxxxxx.azuredatabricks.net"

# Personal access token (starts with "dapi"). Create one at:
#   $DATABRICKS_HOST/settings/user/developer/access-tokens
DATABRICKS_TOKEN="dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"


# --- End-to-end mount test target -------------------------------------------

# A Unity Catalog volume you can read, in /Volumes form:
#   /Volumes/<catalog>/<schema>/<volume>
FUSE4DBRICKS_TEST_VOLUME="/Volumes/my_catalog/my_schema/my_volume"

# A known existing file inside that volume, given as a path RELATIVE to
# FUSE4DBRICKS_TEST_VOLUME (used for stat / cat / multi-chunk read checks).
# Pick something non-trivial in size if you want to exercise chunk streaming
# and prefetch (the chunk size is 8 MiB).
#   e.g. "subdir/data.csv"
FUSE4DBRICKS_TEST_FILE="path/to/file.csv"



